{
  "manifest_version": 3,
  "name": "Community Lead Assistant",
  "version": "2.0.0",
  "description": "Find high-intent community leads, generate manual outreach drafts, and sync to your dashboard.",
  "permissions": ["storage", "tabs", "activeTab", "scripting", "downloads", "clipboardWrite"],
  "host_permissions": [
    "http://localhost/*",
    "http://localhost:3000/*",
    "http://127.0.0.1/*",
    "https://communityleadassistant.com/*",
    "https://www.communityleadassistant.com/*",
    "https://*.vercel.app/*",
    "https://www.reddit.com/*",
    "https://reddit.com/*",
    "https://old.reddit.com/*",
    "https://new.reddit.com/*",
    "https://www.indiehackers.com/*",
    "https://indiehackers.com/*",
    "https://www.facebook.com/*",
    "https://m.facebook.com/*",
    "https://*.slack.com/*",
    "https://discord.com/*",
    "https://*.discord.com/*",
    "https://web.telegram.org/*",
    "https://web.whatsapp.com/*",
    "https://www.linkedin.com/*",
    "https://linkedin.com/*",
    "https://www.producthunt.com/*",
    "https://producthunt.com/*",
    "https://x.com/*",
    "https://www.x.com/*",
    "https://twitter.com/*",
    "https://www.twitter.com/*"
  ],
  "externally_connectable": {
    "matches": [
      "http://localhost/*",
      "http://localhost:3000/*",
      "http://127.0.0.1/*",
      "https://communityleadassistant.com/*",
      "https://www.communityleadassistant.com/*",
      "https://*.vercel.app/*"
    ]
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.reddit.com/*",
        "https://reddit.com/*",
        "https://old.reddit.com/*",
        "https://new.reddit.com/*",
        "https://www.indiehackers.com/*",
        "https://indiehackers.com/*",
        "https://www.facebook.com/*",
        "https://m.facebook.com/*",
        "https://*.slack.com/*",
        "https://discord.com/*",
        "https://*.discord.com/*",
        "https://web.telegram.org/*",
        "https://web.whatsapp.com/*",
        "https://www.linkedin.com/*",
        "https://linkedin.com/*",
        "https://www.producthunt.com/*",
        "https://producthunt.com/*",
        "https://x.com/*",
        "https://www.x.com/*",
        "https://twitter.com/*",
        "https://www.twitter.com/*"
      ],
      "js": [
        "adapters/reddit.js",
        "adapters/indiehackers.js",
        "adapters/facebook.js",
        "adapters/slack.js",
        "adapters/discord.js",
        "adapters/telegram.js",
        "adapters/whatsapp.js",
        "adapters/linkedin.js",
        "adapters/producthunt.js",
        "adapters/twitter.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Community Lead Assistant",
    "default_popup": "popup/popup.html"
  }
}
