{
  "manifest_version": 3,
  "name": "Community Lead Assistant - Manual Outreach Logger",
  "version": "7.0.0",
  "description": "Safely scans visible community content, scores leads, generates local outreach drafts, and logs manual review workflows.",
  "permissions": ["storage", "tabs", "activeTab", "scripting", "downloads", "clipboardWrite"],
  "host_permissions": [
    "https://www.reddit.com/*",
    "https://reddit.com/*",
    "https://old.reddit.com/*",
    "https://new.reddit.com/*",
    "https://www.indiehackers.com/*",
    "https://indiehackers.com/*",
    "https://www.startupschool.org/*",
    "https://startupschool.org/*",
    "https://microconf.com/*",
    "https://*.microconf.com/*",
    "https://microconfconnect.com/*",
    "https://*.microconfconnect.com/*",
    "https://*.slack.com/*",
    "https://discord.com/*",
    "https://*.discord.com/*",
    "https://www.facebook.com/*",
    "https://m.facebook.com/*",
    "https://web.whatsapp.com/*",
    "https://web.telegram.org/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Community Lead Assistant",
    "default_popup": "popup/popup.html"
  }
}
