# Community Lead Assistant environment template
# Copy to apps/web/.env.local for local development, and add the same keys in Vercel Project Settings.

# Public app metadata
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SITE_DOMAIN=communityleadassistant.com
NEXT_PUBLIC_SUPPORT_EMAIL=support@communityleadassistant.com
NEXT_PUBLIC_EXTENSION_ID=

# Supabase public client values
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Server-only Supabase key. Never expose this in browser code.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Admin access
ADMIN_EMAILS=lunasticgold@gmail.com
EXTENSION_SHARED_SECRET=replace-with-a-long-random-secret

# Supabase OAuth provider setup lives in the Supabase dashboard.
# Keep these only if your deployment process syncs provider credentials from env.
SUPABASE_AUTH_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_GOOGLE_CLIENT_SECRET=

# Gemini draft generation
AI_PROVIDER=gemini
GEMINI_API_KEY=
AI_DEFAULT_MODEL=gemini-2.5-flash
AI_DRAFTS_ENABLED=true

# Billing, optional until paid plans go live
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_PRICE_ID=
STRIPE_PRO_PRICE_ID=
STRIPE_AGENCY_PRICE_ID=

# Trial and retention defaults
TRIAL_DAYS=7
TRIAL_LEAD_LIMIT=50
TRIAL_AI_DRAFT_LIMIT=50
DATA_RETENTION_DAYS=90

# Knowledge upload policy
MAX_KNOWLEDGE_FILE_MB=10
ALLOWED_KNOWLEDGE_FILE_TYPES=pdf,docx,txt
